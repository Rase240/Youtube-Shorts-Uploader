# ── Gemini API ──────────────────────────────────────────
# Your Gemini API key used by the bot to analyze videos and generate titles/descriptions/tags.
GEMINI_API_KEY=your_gemini_api_key_here

# ── YouTube OAuth ────────────────────────────────────────
# Path to your client_secrets.json file downloaded from Google Cloud Console.
CLIENT_SECRETS_PATH=your_client_secrets_json_path_here

# ── Upload Defaults ──────────────────────────────────────
# Default privacy status for uploads. Options: 'public', 'private', or 'unlisted'.
DEFAULT_PRIVACY=your_default_privacy_here

# Whether to notify subscribers of new uploads by default. Options: 'true' or 'false'.
DEFAULT_NOTIFY_SUBSCRIBERS=your_default_notify_subscribers_here

# Whether to allow other websites to embed your uploaded videos. Options: 'true' or 'false'.
DEFAULT_EMBEDDABLE=your_default_embeddable_here
